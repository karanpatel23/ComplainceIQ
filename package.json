{
  "name": "complianceiq",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "ComplianceIQ industrial audit-readiness platform for manufacturers.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node --env-file-if-exists=.env apps/api/src/server.js",
    "start": "node --env-file-if-exists=.env apps/api/src/server.js",
    "build": "npm run typecheck && npm run lint && npm --workspaces --if-present run build",
    "typecheck": "node scripts/check-js.mjs",
    "lint": "node scripts/lint.mjs",
    "test": "node --test tests/*.test.js",
    "db:migrate": "node --env-file-if-exists=.env packages/db/src/migrate.js",
    "admin:provision": "node --env-file-if-exists=.env packages/db/src/provision-admin.js",
    "seed:demo": "node --env-file-if-exists=.env packages/db/src/seed.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "pg": "^8.16.0"
  }
}
