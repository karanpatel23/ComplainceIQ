NODE_ENV=development
DEPLOYMENT_PROFILE=local
PROCESS_ROLE=api-and-worker
LOG_LEVEL=debug
PORT=4000
API_HOST=127.0.0.1
WORKER_HEALTH_PORT=4001
APP_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4000
REPOSITORY_BACKEND=file
STORAGE_BACKEND=local
UPLOAD_DIR=data/private-storage
MAX_UPLOAD_MB=25
SESSION_SECRET=development-only-replace-me
MALWARE_SCAN_ENABLED=true
MALWARE_SCANNER_PROVIDER=mock
MALWARE_SCAN_FAIL_POLICY=open
AI_ENABLED=true
AI_PROVIDER=mock
ENABLE_DEMO_DATA=false
