NODE_ENV=development
PORT=4000
API_HOST=127.0.0.1
APP_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4000

# Required for production. Set REPOSITORY_BACKEND=file and leave DATABASE_URL blank only for a local smoke test.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/complianceiq
REPOSITORY_BACKEND=postgres

# Required in production. Use at least 32 random bytes.
SESSION_SECRET=replace-with-a-long-random-production-secret

# Local development storage. Production requires STORAGE_BACKEND=s3.
STORAGE_BACKEND=local
UPLOAD_DIR=data/private-storage
MAX_UPLOAD_MB=25
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false
SIGNED_URL_EXPIRY_SECONDS=300

# Local in-process queue. The adapter boundary supports a future external queue.
QUEUE_BACKEND=local
QUEUE_CONCURRENCY=1
QUEUE_MAX_RETRIES=3

# Mock scanning is for development/testing only. Suspicious files are always blocked.
MALWARE_SCAN_ENABLED=false
MALWARE_SCAN_REQUIRED_IN_PRODUCTION=false
MALWARE_SCANNER_PROVIDER=mock

ENABLE_DEMO_DATA=false
ADMIN_EMAIL=admin@complianceiq.local
ADMIN_PASSWORD=

# Optional AI Evidence Intelligence. Keep disabled unless a backend provider is configured.
AI_ENABLED=false
AI_PROVIDER=openai
AI_MAX_FILE_TEXT_CHARS=12000
AI_CONFIDENCE_THRESHOLD=0.8
AI_REVIEW_REQUIRED_THRESHOLD=0.7

# One-time initial administrator provisioning. Keep these out of committed production files.
PROVISION_ORGANIZATION_NAME=
PROVISION_ADMIN_NAME=
PROVISION_ADMIN_EMAIL=
PROVISION_ADMIN_PASSWORD=

# Optional integrations. Core audit packet workflow does not require these.
TEST_DATABASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=
SMTP_HOST=
SMTP_PORT=
SMTP_USE_TLS=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
